## Kontent.ai
KONTENT_ENVIRONMENT_ID=
KONTENT_DELIVERY_API_KEY=

# Bare domain of the Kontent.ai web app (used by Delivery API, MAPI, and smart-link editor redirects).
# Defaults to "kontent.ai". Set to "devkontentmasters.com" for QA.
# Public — used both server-side (Delivery/MAPI proxy) and in the browser (Smart Link baseUrl).
# NEXT_PUBLIC_KONTENT_URL=

# (Optional) used only for model generation
KONTENT_MANAGEMENT_API_KEY=

## Auth0 (public client + PKCE — no Auth0 client secret needed)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

## App
APP_BASE_URL=http://localhost:3000

# 32+ byte random string used to encrypt the local session cookie.
# This is NOT an Auth0 credential — it never leaves this server.
# Generate locally, e.g. `openssl rand -base64 32`.
SESSION_PASSWORD=
